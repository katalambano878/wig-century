  "scripts": {
    "postinstall": "patch-package",
    "build": "next build",
    "clean": "node -e \"const fs=require('fs');const path=require('path');const d=path.join(process.cwd(),'.next');if(fs.existsSync(d)){fs.rmSync(d,{recursive:true});console.log('Removed .next');}const c=path.join(process.cwd(),'node_modules','.cache');if(fs.existsSync(c)){fs.rmSync(c,{recursive:true});console.log('Removed node_modules/.cache');}\"",
    "compress-images": "node scripts/compress-images.mjs",
    "dev": "cross-env NODE_ENV=development next dev -H 0.0.0.0 -p 3005",
    "lint": "next lint",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:migrate": "supabase link && supabase db push",
    "db:migrate": "node scripts/run-migration.mjs",
    "create-admin": "node scripts/create-admin-user.mjs"
  },
  "version": "0.1.0"
